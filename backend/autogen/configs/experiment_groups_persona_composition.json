{
  "schema_version": "project_timeline_v2",
  "dataset_name": "persona_composition_timeline_benchmark_v1",
  "description": "面向教育场景的 persona 组合对话生成实验。每个 group 使用不同学生 persona 组合，用于生成不同协作质量、冲突程度和推进方式的学生团队连续对话。",
  "output_prefix": "persona_composition_timeline_dataset",
  "manager_system_message": "你是学生项目讨论的流程协调者。你的职责是保持讨论自然、减少机械重复、在需要时轻微拉回项目主线，并让会议在自然停点结束。不要替学生评分，只负责让不同 persona 组合自然互动。",
  "default_groupchat": {
    "max_round": 12,
    "speaker_selection_method": "auto",
    "allow_repeat_speaker": false,
    "temperature": 0.8,
    "tags": [
      "timeline_v2",
      "persona_composition"
    ]
  },
  "generation_settings": {
    "min_effective_messages": 8,
    "min_participating_speakers": 3,
    "repair_max_rounds": 2,
    "enable_closer": true,
    "enable_event_controller": false,
    "enable_quality_diagnostics": true,
    "session_timeout_seconds": 120,
    "incremental_conversation_timeline": true
  },
